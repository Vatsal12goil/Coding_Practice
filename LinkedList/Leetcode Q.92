# Reverse LinkedList II


class Solution:
    def reverseBetween(self, head: Optional[ListNode], left: int, right: int) -> Optional[ListNode]:

        arr = []

        while head:
            arr.append(head)
            head = head.next

        left -= 1
        right -= 1

        while left < right:
            arr[left], arr[right] = arr[right], arr[left]

            left += 1
            right -= 1

        for i in range(len(arr) - 1):
            arr[i].next = arr[i + 1]

        arr[-1].next = None

        return arr[0]
