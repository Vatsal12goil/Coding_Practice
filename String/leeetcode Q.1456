# Max number of vowels in a given substring of fixed length 
class Solution:
    def maxVowels(self, s: str, k: int) -> int:

        vowels = "aeiou"

        count = 0

        for i in range (k):
            if s[i] in vowels:
              count += 1
        max_count = count

        for i in range(k, len(s)):

            # Remove left character
            if s[i-k] in vowels:
                count -= 1

            # Add new right character
            if s[i] in vowels:
                count += 1

            max_count = max(max_count, count)

        return max_count
*** used the concept of sliding window
