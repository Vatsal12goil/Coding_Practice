/**   # Binary tree Postorder Traversal   **/

class Solution:
    def postorderTraversal(self, root: Optional[TreeNode]) -> List[int]:
        result = []
        def postorder(root):      # implement by the helper function 
            if root is None :
                return 
            postorder(root.left)
            postorder(root.right)
            result.append(root.val)
        postorder(root)
        return result
