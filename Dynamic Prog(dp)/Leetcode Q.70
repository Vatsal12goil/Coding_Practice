## Climbing Stairs DP Question 

class Solution:
    def climbStairs(self, n: int) -> int:
        dp = {}
        def solve(n,t):
            if n == t:
                return 1 
            if n > t :
                return 0
            if n in dp:
               return dp[n]

            dp[n] = solve(n+1,t) + solve(n+2,t)
            return dp[n]
        return solve(0,n)

            
