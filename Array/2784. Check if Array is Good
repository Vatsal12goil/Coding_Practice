1st leetcode Problem 

from collections import Counter

class Solution:
    def isGood(self, nums: List[int]) -> bool:

        freq = Counter(nums)

        max_ele = max(nums)

        if freq[max_ele] != 2:
            return False

        for i in range(1, max_ele):

            if freq[i] != 1:
                return False

        return True
