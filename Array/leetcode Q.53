# Kadane's Algo approach 
class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        max_sum = nums[0]
        curr_sum = nums[0]
        
        for i in range(1,len(nums)):
            curr_sum = max(nums[i],nums[i]+curr_sum)
            max_sum = max(curr_sum,max_sum)
        return max_sum


# Pehla element already consider ho chuka tha initialization mein.That's why wwe have starteed from 1 not 0 in loop 
# then if we try to set max_sum and curr_sum to 0 for using loop start from 0 then negative array se deal mein dikkat hogi instead we can do one thing set max_sum as float('-inf') then
# u can use loop from 0.

